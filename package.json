{
  "name": "plantilla-rn-front",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/lato": "^0.4.1",
    "@expo-google-fonts/quicksand": "^0.4.1",
    "@expo/metro-runtime": "~55.0.10",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@reduxjs/toolkit": "^2.11.2",
    "date-fns": "^4.1.0",
    "expo": "^55.0.0",
    "expo-camera": "~55.0.16",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.28",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.14",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.73.1",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.15.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-ml-kit/text-recognition",
          "react-native-vector-icons"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "private": true
}
