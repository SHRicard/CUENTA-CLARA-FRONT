{
  "expo": {
    "slug": "cuenta-clara",
    "name": "Cuentas Claras",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rricardo.cuenta.clara"
    },
    "android": {
      "package": "com.rricardo.cuenta.clara",
      "adaptiveIcon": {
        "foregroundImage": "./assets/CUENTA-CLARA.png",
        "backgroundColor": "#000000"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "@react-native-google-signin/google-signin",
      "expo-localization",
      "@react-native-vector-icons/material-design-icons",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-blanco.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "enableFullScreenImage_legacy": true,
          "dark": {
            "image": "./assets/splash-oscuro.png",
            "backgroundColor": "#12121c"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ba935f89-ce59-4a09-b97e-7d16fb433396"
      }
    }
  }
}
