eEXPO_PUBLIC_TYPE_DEPLOY=development

# Google OAuth — generar en https://console.cloud.google.com/apis/credentials
# IMPORTANTE: nunca pongas el client secret aquí. Los EXPO_PUBLIC_* quedan
# embebidos en el bundle y son públicos.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
